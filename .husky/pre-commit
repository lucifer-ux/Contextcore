#!/usr/bin/env sh

# Detect Python
if [ -x "./.venv/bin/python" ]; then
  PYTHON_CMD="./.venv/bin/python"
elif [ -f "./.venv/Scripts/python.exe" ]; then
  PYTHON_CMD="./.venv/Scripts/python.exe"
elif [ -x "./venv/bin/python" ]; then
  PYTHON_CMD="./venv/bin/python"
elif [ -f "./venv/Scripts/python.exe" ]; then
  PYTHON_CMD="./venv/Scripts/python.exe"
elif [ -f "./myvenv/Scripts/python.exe" ]; then
  PYTHON_CMD="./myvenv/Scripts/python.exe"
elif command -v python >/dev/null 2>&1; then
  PYTHON_CMD="python"
elif command -v py >/dev/null 2>&1; then
  PYTHON_CMD="py"
else
  echo "Python interpreter not found."
  exit 1
fi

# Ensure tools exist
for pkg in ruff black pytest; do
  if ! "$PYTHON_CMD" -c "import $pkg" >/dev/null 2>&1; then
    echo "$pkg not installed. Install with: pip install $pkg"
    exit 1
  fi
done

# Get staged Python files
FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep '\.py$')

if [ -n "$FILES" ]; then
  echo "Running Ruff autofix..."
  $PYTHON_CMD -m ruff check $FILES --fix

  echo "Running Black formatter..."
  $PYTHON_CMD -m black $FILES

  # Re-add formatted files
  echo "$FILES" | xargs git add
else
  echo "No Python files staged."
fi

# Run tests AFTER formatting
echo "Running pytest..."
MISSING_DEPS=$("$PYTHON_CMD" -c "import importlib.util as u; deps=['textual','rapidfuzz','watchdog','sqlite_vec']; missing=[d for d in deps if u.find_spec(d) is None]; print(' '.join(missing))")
if [ -n "$MISSING_DEPS" ]; then
  echo "Skipping pytest: missing runtime deps: $MISSING_DEPS"
else
  if "$PYTHON_CMD" -c "import pytest_timeout" >/dev/null 2>&1; then
    $PYTHON_CMD -m pytest tests/ -v --timeout=60 --tb=short
  else
    echo "pytest-timeout not installed; running pytest without --timeout"
    $PYTHON_CMD -m pytest tests/ -v --tb=short
  fi
fi

echo "Pre-commit checks passed ✅"
