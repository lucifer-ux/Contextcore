#!/usr/bin/env sh

if [ -x "./.venv/bin/python" ]; then
  PYTHON_CMD="./.venv/bin/python"
elif [ -x "./venv/bin/python" ]; then
  PYTHON_CMD="./venv/bin/python"
elif [ -x "./myvenv/Scripts/python.exe" ]; then
  PYTHON_CMD="./myvenv/Scripts/python.exe"
elif command -v python >/dev/null 2>&1; then
  PYTHON_CMD="python"
elif command -v py >/dev/null 2>&1; then
  PYTHON_CMD="py"
else
  echo "Python interpreter not found for pytest hook."
  exit 1
fi

if ! "$PYTHON_CMD" -c "import pytest" >/dev/null 2>&1; then
  echo "pytest is not installed for $PYTHON_CMD"
  echo "Install it with: $PYTHON_CMD -m pip install pytest pytest-timeout"
  exit 1
fi

if ! "$PYTHON_CMD" -c "import pycodestyle" >/dev/null 2>&1; then
  echo "pycodestyle is not installed for $PYTHON_CMD"
  echo "Install it with: $PYTHON_CMD -m pip install pycodestyle"
  exit 1
fi

STAGED_PY_DIFF=$(git diff --cached --diff-filter=ACMR -- '*.py')
HOOK_FAILED=0

if [ -n "$STAGED_PY_DIFF" ]; then
  echo "Running PEP 8 lint (pycodestyle) on staged Python changes..."
  if ! printf "%s\n" "$STAGED_PY_DIFF" | "$PYTHON_CMD" -m pycodestyle --diff --max-line-length=88 --ignore=E203,W503; then
    HOOK_FAILED=1
  fi
fi

echo "Running pytest suite..."
if ! "$PYTHON_CMD" -m pytest tests/ -v --timeout=60 --tb=short; then
  HOOK_FAILED=1
fi

if [ "$HOOK_FAILED" -ne 0 ]; then
  echo "husky - pre-commit checks failed"
  exit 1
fi
